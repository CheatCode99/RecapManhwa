{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main",
    "kokoro-tts"
  ],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-get-all-windows",
    "dialog:default",
    "fs:read-files",
    "fs:write-files",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read",
    "fs:allow-write"
  ]
}